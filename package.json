{
  "name": "spacekit",
  "description": "Local-first developer toolbox: JSON, codec, JWT, timestamp, hash. Zero network, no data collection.",
  "private": true,
  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "dev:web": "vite --config vite.web.config.ts",
    "build:web": "vite build --config vite.web.config.ts",
    "preview:web": "vite preview --config vite.web.config.ts",
    "deploy:web": "pnpm build:web && wrangler deploy",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/gen-icons.mjs",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "@types/crypto-js": "^4.2.2",
    "@types/js-beautify": "^1.14.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "@wxt-dev/module-react": "^1.1.5",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6",
    "wrangler": "^4.98.0",
    "wxt": "^0.20.25"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.10.8",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/lint": "^6.8.4",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.4",
    "@lezer/highlight": "^1.2.1",
    "@tailwindcss/vite": "^4.3.0",
    "codemirror": "^6.0.1",
    "crypto-js": "^4.2.0",
    "csso": "^5.0.5",
    "fast-xml-parser": "^5.8.0",
    "graphql": "^16.14.1",
    "js-beautify": "^1.15.4",
    "json5": "^2.2.3",
    "jsonpath-plus": "^10.4.0",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "sm-crypto": "^0.4.0",
    "smol-toml": "^1.6.1",
    "spark-md5": "^3.0.2",
    "sql-formatter": "^15.8.0",
    "tailwindcss": "^4.3.0",
    "xml-formatter": "^3.7.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  }
